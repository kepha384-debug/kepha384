
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: comments
    // Document ID: {commentId}
    // Fields:
    //   - id: string (optional)
    //   - mediaId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - text: string (required, max 500 chars)
    //   - timestamp: string (required, ISO 8601)
    //   - isApproved: boolean (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "lkdad2333@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['mediaId', 'userId', 'userName', 'text', 'timestamp', 'isApproved']) &&
             data.mediaId is string && data.mediaId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.userName is string && data.userName.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.timestamp is string &&
             data.isApproved is bool;
    }

    match /comments/{commentId} {
      // Anyone can read approved comments
      // Admins can read all comments
      allow read: if resource.data.isApproved == true || isAdmin();

      // Authenticated users can create unapproved comments for themselves
      allow create: if isAuthenticated() && 
                      isValidComment(request.resource.data) &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.isApproved == false;

      // Admins can update (approve/disapprove) or delete any comment
      // Users can delete their own comments
      allow update: if isAdmin() && isValidComment(request.resource.data);
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }
  }
}
